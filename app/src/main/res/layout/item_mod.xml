<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_mod_card"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="8dp"
    android:padding="12dp">

    <!-- Mod Icon -->
    <ImageView
        android:id="@+id/mod_icon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_icon_placeholder"
        android:layout_marginEnd="12dp"/>

    <!-- Text Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/mod_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/mod_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/mod_downloads"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7C5CBF"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Install Button -->
    <Button
        android:id="@+id/btn_install"
        android:layout_width="80dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:text="Install"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:backgroundTint="#7C5CBF"
        android:paddingHorizontal="4dp"/>

</LinearLayout>
