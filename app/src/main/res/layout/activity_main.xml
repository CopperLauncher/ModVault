<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A120A"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_cu_logo"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ModVault"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Content area fills remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- BROWSE TAB -->
        <LinearLayout
            android:id="@+id/layout_browse"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Source Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:background="#1A120A">
                <Button
                    android:id="@+id/btn_modrinth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Modrinth"
                    android:textSize="13sp"
                    android:backgroundTint="#B87333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_curseforge"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CurseForge"
                    android:textSize="13sp"
                    android:backgroundTint="#241810"
                    android:textColor="#AAAAAA"
                    android:layout_marginStart="4dp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
            <!-- Content Type Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp"
                android:background="#1A120A">
                <Button
                    android:id="@+id/btn_type_mods"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mods"
                    android:textSize="11sp"
                    android:backgroundTint="#B87333"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="3dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_type_resourcepack"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Res Packs"
                    android:textSize="11sp"
                    android:backgroundTint="#241810"
                    android:textColor="#AAAAAA"
                    android:layout_marginEnd="3dp"
                    style="@style/Widget.MaterialComponents.Button"/>
                <Button
                    android:id="@+id/btn_type_shader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Shaders"
                    android:textSize="11sp"
                    android:backgroundTint="#241810"
                    android:textColor="#AAAAAA"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="#1A120A">

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:hint="Search mods…"
                    android:textColorHint="#888888"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_search"
                    android:paddingHorizontal="14dp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </LinearLayout>

            <!-- Filters Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="8dp"
                android:background="#1A120A">

                <Spinner
                    android:id="@+id/spinner_version"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="#241810"
                    android:spinnerMode="dropdown"/>

                <Spinner
                    android:id="@+id/spinner_loader"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="#241810"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <!-- Progress -->
            <ProgressBar
                android:id="@+id/browse_progress"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:indeterminate="true"
                android:indeterminateTint="#B87333"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:visibility="gone"/>

            <!-- Mod List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/browse_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="8dp"/>

            <!-- Empty state -->
            <TextView
                android:id="@+id/empty_browse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No mods found"
                android:textColor="#666"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

            <!-- Load More -->
            <Button
                android:id="@+id/btn_load_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Load More"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B87333"
                android:layout_margin="10dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- INSTALLED TAB -->
        <LinearLayout
            android:id="@+id/layout_installed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Installed Mods"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/installed_recycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/empty_installed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No mods installed yet"
                android:textColor="#666"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- SETTINGS TAB -->
        <LinearLayout
            android:id="@+id/layout_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- Instances Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Instance"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/instances_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>
            <Button
                android:id="@+id/btn_scan_instances"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan for Instances"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B87333"
                android:layout_marginBottom="16dp"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginBottom="16dp"/>
            <!-- Saved Paths Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Saved Paths"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/saved_paths_recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginBottom="16dp"/>
            <!-- Manual Folder Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mods Folder"
                android:textColor="#BBBBBB"
                android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tv_folder_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No folder selected"
                android:textColor="#888888"
                android:textSize="11sp"
                android:background="@drawable/bg_search"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_choose_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Instance Folder"
                android:textColor="#FFFFFF"
                android:backgroundTint="#B87333"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#333"
                android:layout_marginVertical="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ModVault v1.0"
                android:textColor="#555"
                android:textSize="11sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Part of the CopperLauncher project"
                android:textColor="#B87333"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="4dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="github.com/CopperLauncher/ModVault"
                android:textColor="#555"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="discord.com/invite/r8wUtzMzUe"
                android:textColor="#555"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Powered by Modrinth API &amp; CurseForge API"
                android:textColor="#444"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A120A"
        app:itemTextColor="#AAAAAA"
        app:itemIconTint="@drawable/bottom_nav_tint"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>
